{
  "name": "2fly-server",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && npx tsc",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed": "npx tsx src/scripts/migrate-json-to-postgres.ts",
    "seed": "npx tsx create-admin-user.ts",
    "start": "npx prisma migrate deploy && node dist/server.js",
    "start:with-seed": "npm run seed && node dist/server.js",
    "setup": "tsx src/scripts/setup.ts",
    "setup:cli": "node setup-cli.js",
    "generate-invite": "node generate-invite.js",
    "migrate:agency-scope": "npm run build && node dist/scripts/migrate-agency-scope.js",
    "recover:portal": "npx tsx src/recover-data.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.50.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/web-push": "^3.6.4",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "googleapis": "^126.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "web-push": "^3.6.7"
  }
}
